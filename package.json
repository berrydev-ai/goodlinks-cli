{
  "name": "@berrydev-ai/goodlinks-cli",
  "version": "0.1.0",
  "description": "TypeScript CLI for the local GoodLinks API",
  "type": "module",
  "bin": {
    "goodlinks": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "skills",
    "skill-data",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --clean",
    "check": "pnpm run typecheck && pnpm test && pnpm run build && pnpm run skill:check",
    "prepack": "pnpm run build && pnpm run skill:check",
    "skill:check": "node --import tsx scripts/generate-skill-reference.ts --check",
    "skill:generate": "node --import tsx scripts/generate-skill-reference.ts",
    "smoke:package": "node --import tsx scripts/smoke-packed-skills.ts",
    "smoke:live": "pnpm run build && node --import tsx scripts/live-smoke.ts",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:watch": "node --import tsx --test --watch tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.29.3",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/berrydev-ai/goodlinks-cli.git"
  },
  "bugs": {
    "url": "https://github.com/berrydev-ai/goodlinks-cli/issues"
  },
  "homepage": "https://github.com/berrydev-ai/goodlinks-cli#readme",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.2",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
